\contentsline {subsection}{\numberline {5.5}Execution Time Analysis}{30}{subsection.5.5}%
\contentsline {paragraph}{Beam Search is the fastest at $\sim $3 seconds on average.}{31}{table.caption.12}%
\contentsline {paragraph}{Hill Climbing peaks at 200 seconds on P4 (Space Exploration).}{31}{table.caption.12}%
\contentsline {paragraph}{A$^*$ at $\sim $71 seconds is explainable but expensive.}{31}{table.caption.12}%
\contentsline {paragraph}{Contrastive Search at $\sim $19 seconds matches Greedy's speed.}{31}{table.caption.12}%
