\contentsline {paragraph}{A$^*$'s improved heuristic helped, but did not solve the problem.}{32}{table.caption.14}%
\contentsline {paragraph}{Hill Climbing lengths equal Greedy lengths exactly.}{32}{table.caption.14}%
\contentsline {paragraph}{Simulated Annealing generates the longest outputs.}{32}{table.caption.14}%
