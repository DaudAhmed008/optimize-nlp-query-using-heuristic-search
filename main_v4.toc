\contentsline {paragraph}{A$^*$ leads by 0.058 over second place.}{23}{table.caption.8}%
\contentsline {paragraph}{Beam Search and Contrastive Search are effectively tied.}{23}{table.caption.8}%
\contentsline {paragraph}{Greedy and Hill Climbing are again tied.}{23}{table.caption.8}%
\contentsline {subsection}{\numberline {5.4}ROUGE-1 Score Analysis}{23}{subsection.5.4}%
\contentsline {paragraph}{A$^*$ achieves high recall from outputs under 15 words.}{23}{table.caption.10}%
\contentsline {paragraph}{Beam Search holds second with a clear margin over Contrastive.}{24}{table.caption.10}%
\contentsline {paragraph}{Hill Climbing and Greedy tie for the third time.}{24}{table.caption.10}%
\contentsline {subsection}{\numberline {5.5}Execution Time Analysis}{24}{subsection.5.5}%
\contentsline {paragraph}{Beam Search is the fastest at 2 seconds on average.}{24}{table.caption.12}%
\contentsline {paragraph}{Hill Climbing peaks at 143 seconds on P2.}{25}{table.caption.12}%
\contentsline {paragraph}{A$^*$ at 114 seconds is explainable but expensive.}{25}{table.caption.12}%
\contentsline {paragraph}{Contrastive Search at 6 seconds is the best practical alternative to Beam Search.}{25}{table.caption.12}%
