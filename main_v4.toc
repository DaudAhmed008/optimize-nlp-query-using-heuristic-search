\contentsline {paragraph}{A$^*$'s length-normalised heuristic helped, but did not solve the problem.}{26}{table.caption.14}%
\contentsline {paragraph}{Hill Climbing lengths equal Greedy lengths exactly.}{26}{table.caption.14}%
\contentsline {paragraph}{Simulated Annealing generates the longest outputs.}{26}{table.caption.14}%
