\contentsline {paragraph}{A$^*$ dominates, but output length is the main driver.}{21}{table.caption.6}%
\contentsline {paragraph}{Beam Search is a solid second.}{22}{table.caption.6}%
\contentsline {paragraph}{Hill Climbing matches Greedy exactly.}{22}{table.caption.6}%
